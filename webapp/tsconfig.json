{
    "compilerOptions": {
        "target": "ES2020",
        "module": "ES2020",
        "moduleResolution": "node",
        "jsx": "react",
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "outDir": "./dist",
        "rootDir": "./src",
        "declaration": false,
        "sourceMap": false,
        "lib": ["ES2020", "DOM"]
    },
    "include": ["src/**/*"],
    "exclude": ["node_modules", "dist"]
}
